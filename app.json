{
  "expo": {
    "name": "Candy",
    "slug": "candy2",
    "version": "1.0.0",
    "scheme": "candy2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.mcthongao.candy2",
      "permissions": ["RECORD_AUDIO","READ_CONTACTS","CALL_PHONE","SEND_SMS"]
    },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
